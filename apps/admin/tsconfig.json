{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "target": "es2022",
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": false,
    "module": "preserve",
    "paths": {
      "@core/*": ["../../libs/admin/core/*"],
      "@ui": ["../../libs/admin/shared/ui/index.ts"],
      "@shared/helpers": ["../../libs/shared/src/helpers/index.ts"],
      "@shared/helpers/form.helper": ["../../libs/shared/src/helpers/form.helper.ts"],
      "@shared/helpers/http.helper": ["../../libs/shared/src/helpers/http.helper.ts"],
      "@shared/helpers/list-query.helper": ["../../libs/shared/src/helpers/list-query.helper.ts"],
      "@shared/*": ["../../libs/admin/shared/*"],
      "@features/*": ["./src/app/features/*"],
      "@env/*": ["./src/environments/*"]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "include": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
